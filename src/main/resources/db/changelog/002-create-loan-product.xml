<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
		xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
		xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
		xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

	<changeSet id="002-create-loan-product" author="helen">

		<createTable tableName="loan_product">

			<column name="id" type="BIGINT" autoIncrement="true">
				<constraints primaryKey="true" nullable="false" />
			</column>

			<column name="principal" type="DECIMAL(15,2)">
				<constraints nullable="false" />
			</column>

			<column name="annual_rate" type="DECIMAL(5,2)">
				<constraints nullable="false" />
			</column>

			<column name="months" type="INT">
				<constraints nullable="false" />
			</column>

			<column name="calculation_type" type="VARCHAR(20)">
				<constraints nullable="false"></constraints>
			</column>
			
		</createTable>

	</changeSet>

</databaseChangeLog>