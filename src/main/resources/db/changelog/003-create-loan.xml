<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
		xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
		xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
		xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

	<changeSet id="003-create-loan" author="helen">

		<createTable tableName="loan">
			<column name="id" type="BIGINT" autoIncrement="true">
				<constraints primaryKey="true" nullable="false" />
			</column>

			<column name="product_name" type="VARCHAR(255)">
				<constraints nullable="false"></constraints>
			</column>
			
			<column name="loan_product_id" type="BIGINT">
				<constraints nullable="false" />
			</column>

			<column name="member_id" type="BIGINT">
				<constraints nullable="false"></constraints>
			</column>

			<column name="calculation_type" type="VARCHAR(50)">
				<constraints nullable="false"></constraints>
			</column>

			<column name="principal" type="DECIMAL(15,2)">
				<constraints nullable="false"></constraints>
			</column>

			<column name="interest_rate" type="DECIMAL(5,2)" />

			<column name="months" type="INT" />

			<column name="total_repayment" type="DECIMAL(15,2)" />

			<column name="total_interest" type="DECIMAL(15,2)" />

			<column name="emi_amount" type="DECIMAL(15,2)" />

		</createTable>

		<addForeignKeyConstraint baseTableName="loan"
			baseColumnNames="loan_product_id" referencedTableName="loan_product"
		 constraintName="fk_loan_product" referencedColumnNames="id"></addForeignKeyConstraint>

		<addForeignKeyConstraint baseTableName="loan"
			baseColumnNames="member_id" referencedTableName="member"
			 constraintName="fk_loan_member" referencedColumnNames="id"></addForeignKeyConstraint>


	</changeSet>

</databaseChangeLog>